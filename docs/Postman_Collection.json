

{
  "info": {
    "name": "BookLeaf Portal API",
    "_postman_id": "f1b60e52-1b3b-4a71-9c20-0c1c3ad5d2a1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:5050" },
    { "key": "authorToken", "value": "" },
    { "key": "adminToken", "value": "" },
    { "key": "ticketId", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "request": { "method": "GET", "url": "{{baseUrl}}/api/health" }
    },
    {
      "name": "Auth - Login (Author)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"priya.sharma@email.com\",\n  \"password\": \"Author@12345\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Auth - Login (Admin)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"admin@bookleaf.test\",\n  \"password\": \"Admin@12345\"\n}"
        },
        "url": "{{baseUrl}}/api/auth/login"
      }
    },
    {
      "name": "Books - My Books (Author)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{authorToken}}" }],
        "url": "{{baseUrl}}/api/books/my"
      }
    },
    {
      "name": "Tickets - Create (Author)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{authorToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"bookExternalId\": null,\n  \"subject\": \"Royalty not received\",\n  \"description\": \"I published 4 months ago and have not received royalty yet. Please check.\"\n}"
        },
        "url": "{{baseUrl}}/api/tickets"
      }
    },
    {
      "name": "Tickets - My Tickets (Author)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{authorToken}}" }],
        "url": "{{baseUrl}}/api/tickets/my"
      }
    },
    {
      "name": "Admin - Ticket Queue",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/tickets?status=Open"
      }
    },
    {
      "name": "Admin - Ticket Detail",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}"
      }
    },
    {
      "name": "Admin - Draft Reply",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}/draft"
      }
    },
    {
      "name": "Admin - Reply",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Authorization", "value": "Bearer {{adminToken}}" },
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"message\": \"Thanks for reaching out. We will check and update within 48 hours.\"\n}"
        },
        "url": "{{baseUrl}}/api/admin/tickets/{{ticketId}}/reply"
      }
    }
  ]
}